quartile = ar_pct < 25 ? 1 : ar_pct < 50 ? 2 : ar_pct < 75 ? 3 : 4

c_q1 = #00d4aa
c_q2 = #6c9eff
c_q3 = #ff9f43
c_q4 = #ff6b6b

line_color = quartile == 1 ? c_q1 : quartile == 2 ? c_q2 : quartile == 3 ? c_q3 : c_q4

h_q1 = hline(25,  "Low/Below Avg", color=color.new(c_q1, 70), linestyle=hline.style_dashed)
h_q2 = hline(50,  "Below Avg/Above Avg", color=color.new(c_q2, 70), linestyle=hline.style_dashed)
h_q3 = hline(75,  "Above Avg/High", color=color.new(c_q3, 70), linestyle=hline.style_dashed)
h_lo = hline(0,   "", color=color.new(color.gray, 95))
h_hi = hline(100, "", color=color.new(color.gray, 95))

fill(h_lo, h_q1, color=color.new(c_q1, 92), title="Low")
fill(h_q1, h_q2, color=color.new(c_q2, 92), title="Below Avg")
fill(h_q2, h_q3, color=color.new(c_q3, 92), title="Above Avg")
fill(h_q3, h_hi, color=color.new(c_q4, 92), title="High")

plot(ar_pct, "FinTurb Market Fragility (Absorption Ratio)", color=line_color, linewidth=2)
hline(50, "Midline", color=color.new(color.white, 80), linestyle=hline.style_dotted)

q_name = quartile == 1 ? "Low" : quartile == 2 ? "Below Avg" : quartile == 3 ? "Above Avg" : "High"

if barstate.islast
    label.new(bar_index + 2, ar_pct, q_name + "\n" + str.tostring(math.round(ar_pct, 1)) + "th pct", style=label.style_label_left, color=color.new(#1a1d29, 20), textcolor=line_color, size=size.small)

alertcondition(ta.crossover(ar_pct, 75), title="FinTurb Market Fragility (Absorption Ratio) enters Q4", message="FinTurb Market Fragility (Absorption Ratio) crossed above 75th percentile. finturb.com")
alertcondition(ta.crossunder(ar_pct, 75), title="FinTurb Market Fragility (Absorption Ratio) exits Q4", message="FinTurb Market Fragility (Absorption Ratio) dropped below 75th percentile. finturb.com")
alertcondition(ar_pct > 90, title="FinTurb Market Fragility (Absorption Ratio) extreme", message="FinTurb Market Fragility (Absorption Ratio) above 90th percentile — extreme reading. finturb.com")

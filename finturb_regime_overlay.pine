//@version=5
// FinTurb Risk Regime Overlay
// (c) AI IntelliCore Limited — finturb.com
// Data through 2026-05-08 — regenerate with generate_pine_scripts.py

indicator("FinTurb Risk Regime Overlay", overlay=true, max_labels_count=50, max_lines_count=100)

bg_opacity = input.int(85, "Background opacity (0=solid, 100=invisible)", 0, 100)
show_markers = input.bool(true, "Show regime transition markers")
show_label = input.bool(true, "Show current regime label")

var int regime = 1
t = timestamp(year, month, dayofmonth, 0, 0, 0)

if t >= timestamp(2026, 5, 8, 0, 0, 0)
    regime := 1  // Normal
else if t >= timestamp(2026, 5, 7, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 5, 6, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 5, 4, 0, 0, 0)
    regime := 1  // Normal
else if t >= timestamp(2026, 5, 1, 0, 0, 0)
    regime := 4  // Crisis
else if t >= timestamp(2026, 4, 30, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 4, 24, 0, 0, 0)
    regime := 1  // Normal
else if t >= timestamp(2026, 4, 23, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 4, 17, 0, 0, 0)
    regime := 1  // Normal
else if t >= timestamp(2026, 4, 16, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 4, 15, 0, 0, 0)
    regime := 1  // Normal
else if t >= timestamp(2026, 4, 14, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 4, 13, 0, 0, 0)
    regime := 1  // Normal
else if t >= timestamp(2026, 4, 9, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 4, 8, 0, 0, 0)
    regime := 4  // Crisis
else if t >= timestamp(2026, 4, 6, 0, 0, 0)
    regime := 1  // Normal
else if t >= timestamp(2026, 4, 2, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 3, 31, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 3, 26, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 3, 25, 0, 0, 0)
    regime := 4  // Crisis
else if t >= timestamp(2026, 3, 24, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 3, 20, 0, 0, 0)
    regime := 4  // Crisis
else if t >= timestamp(2026, 3, 19, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 3, 16, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 3, 13, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 3, 10, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 3, 9, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 3, 2, 0, 0, 0)
    regime := 4  // Crisis
else if t >= timestamp(2026, 2, 27, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 2, 25, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 2, 23, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 2, 19, 0, 0, 0)
    regime := 2  // Elevated
else if t >= timestamp(2026, 2, 18, 0, 0, 0)
    regime := 3  // Stress
else if t >= timestamp(2026, 2, 17, 0, 0, 0)
    regime := 4  // Crisis
else
    regime := 1  // Default

c_bg = regime == 1 ? color.new(#00d4aa, bg_opacity) : regime == 2 ? color.new(#ffe66d, bg_opacity) : regime == 3 ? color.new(#ff9f43, bg_opacity) : regime == 4 ? color.new(#ff6b6b, bg_opacity) : color.new(color.black, 100)
c_solid = regime == 1 ? #00d4aa : regime == 2 ? #ffe66d : regime == 3 ? #ff9f43 : regime == 4 ? #ff6b6b : color.gray
r_name = regime == 1 ? "NORMAL" : regime == 2 ? "ELEVATED" : regime == 3 ? "STRESS" : regime == 4 ? "CRISIS" : "—"

bgcolor(c_bg, title="Regime background")

if show_label and barstate.islast
    label.new(bar_index + 3, high, "FinTurb: " + r_name, style=label.style_label_left, color=color.new(#1a1d29, 20), textcolor=c_solid, size=size.normal)

regime_prev = regime[1]
if show_markers and regime != regime_prev and not na(regime_prev)
    line.new(bar_index, low, bar_index, high, color=c_solid, style=line.style_dashed, width=1)
    label.new(bar_index, low, "→ " + r_name, style=label.style_label_up, color=color.new(#1a1d29, 30), textcolor=c_solid, size=size.tiny)

alertcondition(regime != regime[1] and regime >= 3, title="FinTurb Stress/Crisis", message="FinTurb regime shifted to stress or crisis. finturb.com")
alertcondition(regime != regime[1], title="FinTurb Regime Change", message="FinTurb regime changed. finturb.com")

//@version=5
indicator("FinTurb Risk Regime Overlay", overlay=true, max_labels_count=500,
     max_lines_count=500, max_boxes_count=500)

// ═══════════════════════════════════════════════════════════════════════════
// DESCRIPTION
// ═══════════════════════════════════════════════════════════════════════════
// Overlays the FinTurb composite risk regime onto any chart.
//
// • Background tint changes with the macro regime (Normal → Crisis)
// • Vertical markers at regime transition dates
// • Separate pane shows the composite risk score (0–100) with threshold bands
//
// Data source: github.com/ai-intellicore/finturb-tradingview-data
// Updated daily ~04:20 UTC after the FinTurb signal pipeline completes.
//
// The regime is market-wide — it applies to every asset, not just the
// one on your chart. When the background turns orange or red, the entire
// cross-asset correlation structure is elevated.
//
// Not investment advice. See finturb.com/terms.

// ═══════════════════════════════════════════════════════════════════════════
// DATA FEED via request.seed()
// ═══════════════════════════════════════════════════════════════════════════
// OHLCV convention:
//   open  = Composite risk score (0–100)
//   high  = Liquidity-adjusted 4-way score (0–100)
//   low   = Absorption Ratio percentile × 100
//   close = Mahalanobis Distance percentile × 100
//   volume = Regime code: 1=Normal, 2=Elevated, 3=Stress, 4=Crisis

[ft_open, ft_high, ft_low, ft_close, ft_volume] = request.seed(
     "ai-intellicore/finturb-tradingview-data",
     "FINTURB_REGIME",
     input.timeframe("1D"))

risk_score     = ft_open
risk_score_4w  = ft_high
ar_pct         = ft_low
md_pct         = ft_close
regime_code    = ft_volume

// ═══════════════════════════════════════════════════════════════════════════
// USER INPUTS
// ═══════════════════════════════════════════════════════════════════════════
show_bg        = input.bool(true,  "Show regime background colour")
bg_opacity     = input.int(85,     "Background opacity (0=solid, 100=invisible)", 0, 100)
show_markers   = input.bool(true,  "Show regime transition markers")
show_label     = input.bool(true,  "Show current regime label")
show_score     = input.bool(true,  "Show risk score in separate pane")

// ═══════════════════════════════════════════════════════════════════════════
// COLOURS
// ═══════════════════════════════════════════════════════════════════════════
c_normal   = color.new(#00d4aa, bg_opacity)  // teal
c_elevated = color.new(#ffe66d, bg_opacity)  // amber
c_stress   = color.new(#ff9f43, bg_opacity)  // orange
c_crisis   = color.new(#ff6b6b, bg_opacity)  // coral
c_none     = color.new(color.black, 100)     // transparent

c_normal_solid   = #00d4aa
c_elevated_solid = #ffe66d
c_stress_solid   = #ff9f43
c_crisis_solid   = #ff6b6b

// ═══════════════════════════════════════════════════════════════════════════
// REGIME BACKGROUND
// ═══════════════════════════════════════════════════════════════════════════
regime_bg = switch
    regime_code == 1 => c_normal
    regime_code == 2 => c_elevated
    regime_code == 3 => c_stress
    regime_code == 4 => c_crisis
    => c_none

bgcolor(show_bg ? regime_bg : c_none, title="Regime background")

// ═══════════════════════════════════════════════════════════════════════════
// REGIME LABEL (current state, top-right corner)
// ═══════════════════════════════════════════════════════════════════════════
regime_name = switch
    regime_code == 1 => "NORMAL"
    regime_code == 2 => "ELEVATED"
    regime_code == 3 => "STRESS"
    regime_code == 4 => "CRISIS"
    => "—"

regime_color_solid = switch
    regime_code == 1 => c_normal_solid
    regime_code == 2 => c_elevated_solid
    regime_code == 3 => c_stress_solid
    regime_code == 4 => c_crisis_solid
    => color.gray

if show_label and barstate.islast
    score_text = str.tostring(math.round(risk_score, 1))
    label_text = "FinTurb: " + regime_name + " (" + score_text + "/100)"
    label.new(bar_index + 3, high, label_text,
         style=label.style_label_left,
         color=color.new(#1a1d29, 20),
         textcolor=regime_color_solid,
         size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════
// REGIME TRANSITION MARKERS
// ═══════════════════════════════════════════════════════════════════════════
regime_changed = ta.change(regime_code) != 0

if show_markers and regime_changed
    line.new(bar_index, low, bar_index, high,
         color=regime_color_solid,
         style=line.style_dashed,
         width=1)
    label.new(bar_index, low,
         "→ " + regime_name,
         style=label.style_label_up,
         color=color.new(#1a1d29, 30),
         textcolor=regime_color_solid,
         size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
// RISK SCORE PANE (separate window)
// ═══════════════════════════════════════════════════════════════════════════
// Note: to display in a separate pane, users should add a second instance
// of this indicator with overlay=false. Alternatively, use the companion
// indicator "FinTurb Risk Score" (non-overlay version).
//
// For now, we plot the score as a non-visible line so it's available in
// the data window and for alerts.
plot(show_score ? risk_score : na, "Risk Score",
     color=regime_color_solid, linewidth=2, display=display.data_window)
plot(show_score ? risk_score_4w : na, "4-Way Score",
     color=color.new(regime_color_solid, 50), linewidth=1,
     style=plot.style_line, display=display.data_window)
plot(show_score ? ar_pct : na, "AR Percentile",
     color=#a78bfa, display=display.data_window)
plot(show_score ? md_pct : na, "MD Percentile",
     color=#378ADD, display=display.data_window)

// ═══════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════
alertcondition(regime_changed and regime_code >= 3,
     title="FinTurb Stress/Crisis Alert",
     message="FinTurb regime shifted to {{plot_0}} — risk score {{plot_1}}/100. Review exposure. finturb.com")

alertcondition(regime_changed,
     title="FinTurb Regime Change",
     message="FinTurb regime changed — new regime {{plot_0}}, risk score {{plot_1}}/100. finturb.com")

alertcondition(risk_score > 75,
     title="FinTurb High Risk",
     message="FinTurb risk score above 75 ({{plot_1}}/100). Consider defensive positioning. finturb.com")
